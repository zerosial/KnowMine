# ─────────────────────────────────────────────
# KnowMine .gitignore
# ─────────────────────────────────────────────

# ── Python ──
apps/backend/.venv/
apps/backend/venv/
apps/backend/__pycache__/
apps/backend/**/__pycache__/
apps/backend/**/*.pyc
apps/backend/**/*.pyo
*.pyc
*.pyo
*.pyd
__pycache__/
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Python 환경 설정 ──
.env
.env.local
.env.*.local
*.env

# ── BGE-M3 모델 캐시 (수 GB) ──
apps/backend/.cache/
.cache/
# HuggingFace 모델 캐시 (로컬 PC에만 존재)
*.bin
*.safetensors
# 단, requirements.txt 등은 포함
!requirements.txt

# ── ChromaDB 데이터 (로컬 벡터 DB, 공유 불필요) ──
apps/backend/data/
data/

# ── 업로드된 파일 (개인 문서) ──
apps/backend/uploads/
uploads/

# ── Node.js / Frontend ──
apps/frontend/node_modules/
node_modules/
apps/frontend/dist/
apps/frontend/build/
.npm
*.tsbuildinfo

# ── Vite / React ──
apps/frontend/.vite/
.vite/

# ── OS ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE / Editor ──
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 임시 파일 ──
*.tmp
*.temp
.temp/
tmp/

# ── Docker ──
.docker/

# ─────────────────────────────────────────────
# artifacts/ 폴더는 GitHub에 포함 (프로젝트 문서)
# ─────────────────────────────────────────────
!artifacts/
!artifacts/**
